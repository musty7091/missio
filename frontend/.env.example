# Local development example
# Vite dev server proxies /api requests to FastAPI.
VITE_API_BASE_URL=/api/v1

# Alternative local direct backend address:
# VITE_API_BASE_URL=http://localhost:8000/api/v1

# Production frontend is served through Cloud Run + Nginx.
# Nginx proxies /api/* to backend using container environment variables:
# MISSIO_BACKEND_API_ORIGIN=https://missio-api-xxxxx.run.app
# MISSIO_BACKEND_API_HOST=missio-api-xxxxx.run.app

# Backend runtime note:
# Automatic daily closing endpoint uses MISSIO_SYSTEM_JOB_SECRET on the backend.
# This frontend file does not store that secret.
